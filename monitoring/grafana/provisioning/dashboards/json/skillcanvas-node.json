{
  "id": null,
  "uid": "skillcanvas-node",
  "title": "SkillCanvas - Node & Containers",
  "description": "node-exporter(호스트 CPU/메모리/디스크/네트워크) + cAdvisor(컨테이너별 CPU/메모리) 계측 기반. Grafana 커뮤니티 대시보드 ID 1860(Node Exporter Full)은 패널 140개짜리 대형 대시보드라 그대로 쓰지 않고, 핵심 지표만 이 프로젝트 스타일로 재구성함.",
  "tags": ["skillcanvas", "node", "infra"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "Overview",
      "type": "link",
      "url": "/d/skillcanvas-overview?${__url_time_range}",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU 사용률 (%)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))) or vector(0)", "legendFormat": "cpu" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "메모리 사용률 (%)",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(100 * (1 - avg(node_memory_MemAvailable_bytes) / avg(node_memory_MemTotal_bytes))) or vector(0)", "legendFormat": "mem" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "루트 파일시스템 사용률 (%)",
      "description": "mountpoint=\"/\" 기준. 컨테이너 기반 환경(예: Docker Desktop/WSL2)에서는 호스트 루트가 다른 경로로 잡혀 No data가 뜰 수 있음 — 실제 배포 대상(EC2 등 리눅스 호스트)에서 재확인 필요.",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(100 * (1 - avg(node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) / avg(node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}))) or vector(0)", "legendFormat": "disk" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load Average (1분)",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "avg(node_load1) or vector(0)", "legendFormat": "load1" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "실행 중인 컨테이너 수",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "count(container_last_seen{name!=\"\"}) or vector(0)", "legendFormat": "containers" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "컨테이너 전체 메모리 사용량",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(container_memory_working_set_bytes{name!=\"\"}) or vector(0)", "legendFormat": "mem" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "Node",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "CPU 사용률 추이 (%)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "(100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])))) or vector(0)", "legendFormat": "cpu" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "메모리 사용량 (Total / Available / Cached)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "avg(node_memory_MemTotal_bytes) or vector(0)", "legendFormat": "total" },
        { "refId": "B", "expr": "avg(node_memory_MemAvailable_bytes) or vector(0)", "legendFormat": "available" },
        { "refId": "C", "expr": "avg(node_memory_Cached_bytes) or vector(0)", "legendFormat": "cached" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Disk & Network",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "디스크 I/O (read / write)",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "sum(rate(node_disk_read_bytes_total[$__rate_interval])) or vector(0)", "legendFormat": "read" },
            { "refId": "B", "expr": "sum(rate(node_disk_written_bytes_total[$__rate_interval])) or vector(0)", "legendFormat": "write" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 10,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "네트워크 I/O (rx / tx, loopback 제외)",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            { "refId": "A", "expr": "sum(rate(node_network_receive_bytes_total{device!=\"lo\"}[$__rate_interval])) or vector(0)", "legendFormat": "rx" },
            { "refId": "B", "expr": "sum(rate(node_network_transmit_bytes_total{device!=\"lo\"}[$__rate_interval])) or vector(0)", "legendFormat": "tx" }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "Bps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 10,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Containers",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "panels": [
        {
          "id": 14,
          "type": "timeseries",
          "title": "컨테이너별 CPU 사용률 (%)",
          "gridPos": { "h": 9, "w": 24, "x": 0, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name!=\"\",cpu=\"total\"}[$__rate_interval])) * 100",
              "legendFormat": "{{name}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 5,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        },
        {
          "id": 15,
          "type": "timeseries",
          "title": "컨테이너별 메모리 사용량",
          "gridPos": { "h": 9, "w": 24, "x": 0, "y": 26 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (name) (container_memory_working_set_bytes{name!=\"\"})",
              "legendFormat": "{{name}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "decbytes",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 5,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        }
      ]
    }
  ]
}
