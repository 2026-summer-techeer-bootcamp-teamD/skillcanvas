{
  "id": null,
  "uid": "skillcanvas-overview",
  "title": "SkillCanvas - Overview",
  "description": "서비스 상태 진입점. 상단 Stat 6개로 요약 후 API → AI → Infra(Postgres) → Business 순으로 상세화. CPU/메모리 패널은 node-exporter/cAdvisor가 아직 없어 제외함(No data 패널을 만들지 않기 위함) — 계측 추가되면 Infra row에 편입.",
  "tags": ["skillcanvas", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "links": [
    {
      "title": "AI Call Metrics",
      "type": "link",
      "url": "/d/skillcanvas-ai-calls?${__url_time_range}",
      "targetBlank": false
    },
    {
      "title": "5xx by Handler",
      "type": "link",
      "url": "/d/skillcanvas-5xx-by-handler?${__url_time_range}",
      "targetBlank": false
    },
    {
      "title": "Business Metrics",
      "type": "link",
      "url": "/d/skillcanvas-business-metrics?${__url_time_range}",
      "targetBlank": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "RPS (요청/초)",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total[$__rate_interval])) or vector(0)",
          "legendFormat": "rps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "p95 응답 지연 (전체)",
      "description": "http_request_duration_highr_seconds 기준 (버킷 60초까지, handler 라벨 없음)",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_highr_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "5xx 에러율 (%)",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(http_requests_total{status=~\"5..\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(http_requests_total[$__rate_interval])), 1e-9)",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DB 커넥션 수",
      "description": "postgres-exporter의 pg_stat_database_numbackends 기준. 상세 사용률은 Infra row 참고.",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_numbackends) or vector(0)",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "AI 호출률 (calls/s)",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(ai_call_total[$__rate_interval])) or vector(0)",
          "legendFormat": "calls/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "AI 실패율 (%)",
      "description": "status=error(Claude 호출 실패) + parse_error(JSON 파싱 실패) 합산 비율",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (sum(rate(ai_call_total{status!=\"success\"}[$__rate_interval])) or vector(0)) / clamp_min(sum(rate(ai_call_total[$__rate_interval])), 1e-9)",
          "legendFormat": "fail rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 7,
      "type": "row",
      "title": "API",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "RPS (상태코드별)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "links": [
        { "title": "5xx by Handler에서 자세히 보기", "url": "/d/skillcanvas-5xx-by-handler?${__url_time_range}", "targetBlank": false }
      ],
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total[$__rate_interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 15,
            "stacking": { "mode": "normal", "group": "A" },
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "5.." },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "응답 지연 p50 / p95 / p99 (전체)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(http_request_duration_highr_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_highr_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_highr_seconds_bucket[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 5,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "AI",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "모델별 호출률 (calls/s)",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "links": [
            { "title": "AI Call Metrics에서 자세히 보기", "url": "/d/skillcanvas-ai-calls?${__url_time_range}", "targetBlank": false }
          ],
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (model) (rate(ai_call_total[$__rate_interval]))",
              "legendFormat": "{{model}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "cps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 10,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "상태별 호출 분포 (calls/s)",
          "description": "success / error / parse_error 스택",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "links": [
            { "title": "AI Call Metrics에서 자세히 보기", "url": "/d/skillcanvas-ai-calls?${__url_time_range}", "targetBlank": false }
          ],
          "targets": [
            {
              "refId": "A",
              "expr": "sum by (status) (rate(ai_call_total[$__rate_interval]))",
              "legendFormat": "{{status}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "cps",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 15,
                "stacking": { "mode": "normal", "group": "A" },
                "spanNulls": true
              }
            },
            "overrides": [
              {
                "matcher": { "id": "byName", "options": "error" },
                "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
              },
              {
                "matcher": { "id": "byName", "options": "parse_error" },
                "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
              }
            ]
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Infra (Postgres)",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "panels": [
        {
          "id": 14,
          "type": "timeseries",
          "title": "Postgres TPS (commit + rollback)",
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "refId": "A",
              "expr": "sum(rate(pg_stat_database_xact_commit{datname!~\"template.*|postgres\"}[$__rate_interval])) + sum(rate(pg_stat_database_xact_rollback{datname!~\"template.*|postgres\"}[$__rate_interval]))",
              "legendFormat": "tps"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "ops",
              "custom": {
                "drawStyle": "line",
                "lineWidth": 1,
                "fillOpacity": 10,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        },
        {
          "id": 15,
          "type": "gauge",
          "title": "DB 커넥션 사용률 (%)",
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "refId": "A",
              "expr": "100 * sum(pg_stat_database_numbackends) / clamp_min(max(pg_settings_max_connections), 1)",
              "legendFormat": "usage"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "percent",
              "min": 0,
              "max": 100,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 70 },
                  { "color": "red", "value": 90 }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
            "showThresholdLabels": false,
            "showThresholdMarkers": true
          }
        }
      ]
    },
    {
      "id": 16,
      "type": "row",
      "title": "Business",
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "panels": [
        {
          "id": 17,
          "type": "timeseries",
          "title": "시간당 증가율 (발행 / 생성 / 가져오기)",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "links": [
            { "title": "Business Metrics에서 자세히 보기", "url": "/d/skillcanvas-business-metrics?${__url_time_range}", "targetBlank": false }
          ],
          "targets": [
            {
              "refId": "A",
              "expr": "sum(increase(workflow_published_total[1h]))",
              "legendFormat": "워크플로우 발행"
            },
            {
              "refId": "B",
              "expr": "sum(increase(skill_created_total[1h]))",
              "legendFormat": "스킬 생성"
            },
            {
              "refId": "C",
              "expr": "sum(increase(skill_imported_total[1h]))",
              "legendFormat": "스킬 가져오기"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "custom": {
                "drawStyle": "bars",
                "fillOpacity": 30,
                "spanNulls": true
              }
            },
            "overrides": []
          },
          "options": {
            "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
            "tooltip": { "mode": "multi" }
          }
        }
      ]
    }
  ]
}
