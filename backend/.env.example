# 이 파일을 복사해서 .env 로 만들고 값을 채우세요.
# (.env 는 git에 올라가지 않음)

APP_ENV=local

# DB — 로컬 Docker Postgres (venv로 백엔드 실행 시 host=localhost)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/skillcanvas

# CORS — 프론트 주소
CORS_ORIGINS=http://localhost:5173

# Clerk (dev 키 — 팀장이 공유)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# 관리자 이메일(콤마 구분). 이 이메일로 첫 로그인하면 is_admin=True 로 생성됨.
ADMIN_EMAILS=admin+clerk_test@test.com
# True면 JWT 아닌 토큰(테스트의 "alice" 등)을 유저 식별자로 허용(개발 STUB). 실제 JWT는 항상 검증.
AUTH_DEV_MODE=true

# Claude(Anthropic) — 백엔드 AI 기능용 개발자 공용키 (팀장이 발급·공유)
# console.anthropic.com → API Keys. Max 구독과 별개(종량제).
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-haiku-4-5
